      "parameters": {
        "jsCode": "const slots = $input.all();\n\nif (slots.length === 0) {\n  return [{\n    json: {\n      email_text: \"Unfortunately, I don't have any available slots in the next 7 days. Please let me know your availability and I'll do my best to accommodate.\"\n    }\n  }];\n}\n\nconst slotList = slots.map((slot, index) => \n  `${index + 1}. ${slot.json.formatted}`\n).join('\\n');\n\nconst emailText = `Here are my available times for a 30-minute call:\n\n${slotList}\n\nPlease reply with your preferred time, and I'll send a calendar invite.\n\nLooking forward to speaking with you!\n\nBest,\nNiffyJade`;\n\nreturn [{ json: { email_text: emailText, available_slots: slots.length } }];"
      },
