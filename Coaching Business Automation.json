    {
      "parameters": {
        "jsCode": "// Scoring Logic\nlet score = 0;\n\n// Get the data object\nconst data = $input.item.json;\n\n// Budget scoring (40 points max)\nconst budget = data[\"What is your coaching budget range?\"];\nif (budget === '$10K+') score += 40;\nelse if (budget === '$5-10K') score += 30;\nelse if (budget === '$2-5K') score += 15;\nelse score += 5;\n\n// Title scoring (25 points max)\nconst title = (data[\"What is your job title?\"] || '').toLowerCase();\nif (title.includes('ceo') || title.includes('founder') || \n    title.includes('president')) score += 25;\nelse if (title.includes('vp') || title.includes('vice president') ||\n         title.includes('director')) score += 20;\nelse if (title.includes('manager') || title.includes('head of')) score += 10;\nelse score += 3;\n\n// Timeline scoring (20 points max)\nconst timeline = data[\"When would you like to start?\"];\nif (timeline === 'ASAP') score += 20;\nelse if (timeline === '1-2 months') score += 15;\nelse if (timeline === '3+ months') score += 8;\nelse score += 3;\n\n// Company size scoring (15 points max)\nconst companySize = data[\"What is your company size?\"];\nconst size = parseInt(companySize);\nif (size >= 500) score += 15;\nelse if (size >= 100) score += 12;\nelse if (size >= 50) score += 8;\nelse score += 4;\n\nreturn {\n  ...data,\n  lead_score: score\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
