    {
      "parameters": {
        "jsCode": "// 1. Get the raw text from the AI output\nconst rawText = $input.item.json.text;\n\n// 2. Strip away the markdown formatting (```json and ```)\nconst cleanJsonString = rawText.replace(/```json/gi, '').replace(/```/gi, '').trim();\n\n// 3. Parse the clean string into a JSON object\nconst parsedData = JSON.parse(cleanJsonString);\n\n// 4. Convert plain text line breaks (\\n) into HTML line breaks (<br>)\n// Also, optionally format bold text (**) to HTML bold (<b>)\nlet htmlContent = parsedData.message\n    .replace(/\\n/g, '<br>')\n    .replace(/\\*\\*(.*?)\\*\\*/g, '<b>$1</b>');\n\n// 5. Build the HTML Email Template\nconst htmlEmail = `\n<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"UTF-8\">\n  <style>\n    body { \n      font-family: 'Segoe UI', Helvetica, Arial, sans-serif; \n      background-color: #f4f7f6; \n      margin: 0; \n      padding: 40px 20px; \n    }\n    .email-container { \n      max-width: 600px; \n      margin: 0 auto; \n      background-color: #ffffff; \n      border-radius: 10px; \n      overflow: hidden; \n      box-shadow: 0 4px 15px rgba(0,0,0,0.05); \n    }\n    .email-header { \n      background-color: #0f172a; /* Dark professional blue/black */\n      color: #ffffff; \n      padding: 25px; \n      text-align: center; \n    }\n    .email-body { \n      padding: 30px; \n      font-size: 16px; \n      line-height: 1.6; \n      color: #333333; \n    }\n    .email-footer { \n      background-color: #f8fafc; \n      padding: 20px; \n      text-align: center; \n      font-size: 13px; \n      color: #64748b; \n      border-top: 1px solid #e2e8f0; \n    }\n  </style>\n</head>\n<body>\n  <div class=\"email-container\">\n    <div class=\"email-header\">\n      <h2 style=\"margin: 0; font-weight: 500; letter-spacing: 1px;\">Nifemi AI Agency</h2>\n    </div>\n    <div class=\"email-body\">\n      ${htmlContent}\n    </div>\n    <div class=\"email-footer\">\n      <p style=\"margin: 0;\">&copy; 2026 Nifemi AI Agency. All rights reserved.</p>\n    </div>\n  </div>\n</body>\n</html>\n`;\n\n// 6. Return the subject and the new HTML email\nreturn {\n  subject: parsedData.subject,\n  htmlMessage: htmlEmail,\n  plainTextMessage: parsedData.message // Keeping the plain one just in case!\n};"
      },
